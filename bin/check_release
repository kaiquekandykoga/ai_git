#!/usr/bin/env ruby
# frozen_string_literal: true

require "net/http"
require "json"
require "optparse"

# Load the gem's version constant directly
require_relative "../lib/ai_git/version"

GEM_NAME = "ai_git"

options = { quiet: false }

OptionParser.new do |opts|
  opts.banner = "Usage: bin/check_release [options]"
  opts.on("-q", "--quiet", "Only exit status, no output") { options[:quiet] = true }
end.parse!

def say(msg, quiet)
  puts msg unless quiet
end

def local_version
  abort("AIGit::VERSION is not defined — check version.rb") unless defined?(AIGit::VERSION)

  AIGit::VERSION
end

def fetch_rubygems_versions
  url = URI("https://rubygems.org/api/v1/versions/#{GEM_NAME}.json")

  Net::HTTP.start(url.host, url.port, use_ssl: true, read_timeout: 5, open_timeout: 5) do |http|
    response = http.get(url.request_uri)

    abort("Failed to fetch RubyGems versions: #{response.code}") unless response.is_a?(Net::HTTPSuccess)

    begin
      json = JSON.parse(response.body)
    rescue JSON::ParserError
      abort("RubyGems returned invalid JSON")
    end

    abort("Unexpected RubyGems API response format") unless json.is_a?(Array)

    json.map { |v| v["number"] }.compact
  end
end

local = local_version
published_versions = fetch_rubygems_versions

if published_versions.include?(local)
  say("✔ #{GEM_NAME} #{local} is already published on RubyGems.", options[:quiet])
  exit 0
else
  say("⚠ #{GEM_NAME} #{local} is NOT published on RubyGems.", options[:quiet])
  say("Publish with:", options[:quiet])
  say("  gem build #{GEM_NAME}.gemspec", options[:quiet])
  say("  gem push #{GEM_NAME}-#{local}.gem", options[:quiet])
  exit 1
end
